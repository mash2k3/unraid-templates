<?xml version="1.0"?>
<Container version="2">
  <Name>mediastorm</Name>
  <Repository>godver3/mediastorm:latest</Repository>
  <Branch>
      <Tag>latest</Tag>
      <TagDescription>Grab the latest development build</TagDescription>
  </Branch>
  <Registry>https://hub.docker.com/r/godver3/mediastorm/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <ReadMe>https://github.com/godver3/mediastorm/blob/master/README.md</ReadMe>
  <Support>https://github.com/godver3/mediastorm/issues</Support>
  <Project>https://github.com/godver3/mediastorm</Project>
  <Discord>https://discord.gg/4qEMz4ay</Discord>
  <Overview>A streaming media server with native mobile and TV apps.&#xD;
  &#xD;
  Discord https://discord.gg/4qEMz4ay </Overview>
  <Category>Downloaders: MediaApp:Video</Category>
  <WebUI>http://[IP]:[PORT:7777]/admin</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/mash2k3/unraid-templates/refs/heads/main/mediastorm.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/godver3/mediastorm/master/mediastorm-square.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Cache" Target="/root/cache" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/mediastorm</Config>
  <Config Name="Timezone" Target="TZ" Default="" Mode="" Description="" Type="Variable" Display="always" Required="true" Mask="false">America/New_York</Config>
  <Config Name="Webui" Target="7777" Default="" Mode="tcp" Description="" Type="Port" Display="always" Required="true" Mask="false">7777</Config>
</Container>
