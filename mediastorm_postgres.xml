<?xml version="1.0"?>
<Container version="2">
  <Name>mediastorm_postgres</Name>
  <Repository>postgres:16-alpine</Repository>
  <Branch/>
  <Registry>https://registry.hub.docker.com/_/postgres/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/godver3/mediastorm/issues</Support>
  <Project>https://www.postgresql.org/</Project>
  <Discord>https://discord.gg/4qEMz4ay</Discord>
  <ReadMe/>
  <Overview>PostgreSQL 16 is a powerful, open source object-relational database system with over 35 years of active development that has earned it a strong reputation for reliability, feature robustness, and performance. This template uses the official PostgreSQL Docker image @ https://hub.docker.com/_/postgres/.</Overview>
  <Category>Network:Management Productivity: Tools:Utilities</Category>
  <WebUI/>
  <TemplateURL>https://raw.githubusercontent.com/mash2k3/unraid-templates/refs/heads/main/mediastorm_postgres.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/mash2k3/unraid-templates/main/icons/mediastorm-postgres.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Port: PostgreSQL access port" Target="5432" Default="5432" Mode="tcp" Description="PostgreSQL TCP connection port." Type="Port" Display="always-hide" Required="true" Mask="false">5432</Config>
  <Config Name="Path: /var/lib/postgresql/data" Target="/var/lib/postgresql/data" Default="/mnt/user/appdata/postgresql16" Mode="rw" Description="PostgreSQL data storage location." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/mediastorm/postgres_data</Config>
  <Config Name="Variable: POSTGRES_PASSWORD" Target="POSTGRES_PASSWORD" Default="" Mode="{3}" Description="Initial superuser password (required)." Type="Variable" Display="always" Required="true" Mask="false">mediastorm</Config>
  <Config Name="Variable: POSTGRES_USER" Target="POSTGRES_USER" Default="" Mode="{3}" Description="Initial superuser name (default: postgres)." Type="Variable" Display="always" Required="false" Mask="false">mediastorm</Config>
  <Config Name="Variable: POSTGRES_DB" Target="POSTGRES_DB" Default="" Mode="{3}" Description="Initial database name (default: postgres)." Type="Variable" Display="always" Required="false" Mask="false">mediastorm</Config>
</Container>
